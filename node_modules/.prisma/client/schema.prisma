// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         UserProfile?
  riskAssessments RiskAssessment[]
  goals           Goal[]
  transactions    Transaction[]
  recommendations PortfolioRecommendation[]
  auditLogs       AuditLog[]
  chatThreads     ChatThread[]
  appointments    Appointment[]
  consents        ConsentRecord[]
}

model UserProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  name       String
  age        Int
  city       String
  occupation String
  language   String   @default("en") // en, hi, ta
  accountNo  String?
  branch     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RiskAssessment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  score     Int
  profile   String // Conservative, Moderate, Aggressive
  answers   Json // Store the raw answers as JSON
  createdAt DateTime @default(now())
}

model Goal {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  target     Float
  current    Float
  targetYear Int
  category   String // Retirement, Safety, Property, Education
  status     String   @default("Building") // Behind, Building, On track
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  date            DateTime
  description     String
  category        String
  amount          Float
  type            String // credit, debit
  isDiscretionary Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model PortfolioRecommendation {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  createdAt DateTime             @default(now())
  status    String               @default("Pending") // Pending, Consented, Rejected
  items     RecommendationItem[]
}

model RecommendationItem {
  id          String                  @id @default(uuid())
  portfolioId String
  portfolio   PortfolioRecommendation @relation(fields: [portfolioId], references: [id])
  productId   String
  product     ProductFact             @relation(fields: [productId], references: [id])
  amount      Float
  percentage  Float
  rationale   String
}

model ProductFact {
  id             String               @id @default(uuid())
  name           String
  category       String
  riskLevel      Int
  expectedReturn String
  liquidity      String
  minInvestment  Float
  taxSaving      Boolean              @default(false)
  disclosure     String
  tag            String?
  allocations    RecommendationItem[]
  createdAt      DateTime             @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  event     String
  category  String // Risk, Advice, Consent, System
  details   Json?
  hash      String
  createdAt DateTime @default(now())
}

model ChatThread {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id                   String     @id @default(uuid())
  threadId             String
  thread               ChatThread @relation(fields: [threadId], references: [id])
  sender               String // user, disha
  text                 String
  rationale            String?
  suitabilityNote      String?
  disclosure           String?
  recommendedProductId String?
  createdAt            DateTime   @default(now())
}

model Appointment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String // Video Call, Branch Visit
  date        DateTime
  time        String
  advisorName String
  branch      String?
  status      String   @default("Pending") // Confirmed, Pending
  createdAt   DateTime @default(now())
}

model ConsentRecord {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  policyVersion    String
  recommendationId String?
  timestamp        DateTime @default(now())
}
