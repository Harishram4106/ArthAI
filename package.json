{
  "name": "arthai-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/api & npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "postinstall": "npx prisma generate --schema=apps/api/prisma/schema.prisma"
  }
}
